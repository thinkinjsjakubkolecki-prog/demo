{
  "name": "dealer-fx-app",
  "version": "0.1.0",
  "private": true,
  "description": "FX dealer client-handling app — built on Echelon framework.",
  "scripts": {
    "start": "npm run sync-fw && concurrently -k -n mock,ng -c magenta,cyan \"npm:mock-server\" \"ng serve\"",
    "start:ng": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "mock-server": "echelon-mock-server --config mock-server.json",
    "lint": "eslint src",
    "sync-fw": "node scripts/sync-fw.mjs"
  },
  "dependencies": {
    "@angular/animations": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@echelon-framework/charts-core": "^0.2.0-rc.5",
    "@echelon-framework/charts-echarts": "^0.2.0-rc.5",
    "@echelon-framework/core": "^0.2.0-rc.5",
    "@echelon-framework/designer-core": "^0.2.0-rc.5",
    "@echelon-framework/designer-page": "^0.2.0-rc.5",
    "@echelon-framework/export-core": "^0.2.0-rc.5",
    "@echelon-framework/expression": "^0.2.0-rc.5",
    "@echelon-framework/functions-core": "^0.2.0-rc.5",
    "@echelon-framework/model": "^0.2.0-rc.5",
    "@echelon-framework/page-builders": "^0.2.0-rc.5",
    "@echelon-framework/runtime": "^0.2.0-rc.5",
    "@echelon-framework/transport-http": "^0.2.0-rc.5",
    "@echelon-framework/transport-mock": "^0.2.0-rc.5",
    "@echelon-framework/transport-ws": "^0.2.0-rc.5",
    "@echelon-framework/widgets-core": "^0.2.0-rc.5",
    "echarts": "^5.4.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.6.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@echelon-framework/eslint-plugin": "^0.2.0-rc.5",
    "@echelon-framework/mock-server": "^0.2.0-rc.5",
    "concurrently": "^9.0.0",
    "typescript": "~5.9.0"
  }
}
